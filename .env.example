# Core / DB / auth
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# AES-256-GCM key for encrypting per-user ClickUp personal tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# ClickUp workspace gate — no OAuth app (not a workspace admin), so sign-in is
# email/password + each user pastes their own personal token at onboarding.
CLICKUP_TEAM_ID=
# Personal API token (app.clickup.com/settings/apps) used for shared reads
CLICKUP_SERVICE_TOKEN=
# written by scripts/register-webhook.ts after the webhook is registered
CLICKUP_WEBHOOK_SECRET=

# Push notifications (phase 3) — generate with: bunx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mitchell@human.marketing

# GitHub (phase 5-6)
GITHUB_TOKEN=
GITHUB_ORG=

# Deploy webhooks (phase 5)
NETLIFY_WEBHOOK_JWS_SECRET=
VERCEL_WEBHOOK_SECRET=
DEPLOY_WEBHOOK_TOKEN=
